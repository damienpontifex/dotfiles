# vim:ft=zsh

# kubectl completion zsh 2> /dev/null 
alias k=kubectl
alias kgp='kubectl get pods'
alias kgd='kubectl get deployment'
alias kgcm='kubectl get configmaps'
alias kgsec='kubectl get secret'
alias kgns='kubectl get namespace'
alias kcn='kubectl config set-context --current --namespace'

# k8s
export KUBE_EDITOR=nvim
# Use ~/.kube/kuberc for kubectl config
export KUBECTL_KUBERC=true
source <(kubectl completion zsh)

# kubectl krew for kubectl plugin management
[[ -d "${HOME}/.krew/bin" ]] && export PATH="${HOME}/.krew/bin:${PATH}"

# alias kcu='kubectl config get-contexts -o name | fzf | xargs -r -I {} kubectl config use-context "{}"'
function kgsecv {
  kubectl get secret "${1}" --output yaml | yq '.data | map_values(@base64d)'
}

